# =============================================================================
# config.env.example — NVIDIA GPU Time-Slicing on RHOAI 3.4
# =============================================================================
# Copy to config/config.env and fill in HF_TOKEN before running deploy.sh

# --- Namespace and model ---
NAMESPACE="time-slicing"
MODEL_NAME="gemma-270m"
HF_MODEL_ID="google/gemma-3-270m"
MODEL_S3_PATH="gemma-3-270m"

# --- HuggingFace (one-time model download only) ---
# Get your token at: https://huggingface.co/settings/tokens
# Gemma is gated — you must accept terms at: https://huggingface.co/google/gemma-3-270m
HF_TOKEN=""

# --- MinIO — cluster-local S3 model storage (rhoai-model-registries namespace) ---
MINIO_NAMESPACE="rhoai-model-registries"
MINIO_ENDPOINT="http://minio.rhoai-model-registries.svc.cluster.local:9000"
MINIO_BUCKET="gemma-models"
MINIO_ACCESS_KEY="minio"
MINIO_SECRET_KEY="minio123"

# --- InferenceService scaling (5 replicas — one per time-sliced virtual GPU) ---
GPU_REPLICAS="5"

# --- vLLM serving parameters (T4 time-sliced constraints) ---
MAX_MODEL_LEN="1024"
GPU_MEMORY_UTILIZATION="0.14"
NUM_GPU_BLOCKS_OVERRIDE="200"

# --- Resources per pod ---
CPU_REQUEST="100m"
MEMORY_REQUEST="2Gi"

# --- Timeouts and polling ---
DEPLOY_TIMEOUT_SECONDS="1200"
TRANSFER_TIMEOUT_SECONDS="1800"
POLL_INTERVAL_SECONDS="30"
